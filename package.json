{
  "name": "ganshale",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node scripts/free-dev-port.mjs",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5180 && node scripts/dev-electron-watch.mjs\"",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "gen:dashboard": "node scripts/write-daily-dashboard.mjs",
    "pack": "npm run build && node scripts/pack-win.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "electron": "^34.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "net.ganshale.desktop",
    "productName": "干啥了",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/active-win/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        "nsis"
      ],
      "executableName": "Ganshale",
      "icon": "build/icon.ico",
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "干啥了",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052",
      "installerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
